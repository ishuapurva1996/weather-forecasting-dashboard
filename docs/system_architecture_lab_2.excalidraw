    {
      "type": "text",
      "id": "ml_code_text",
      "x": 1232,
      "y": 425,
      "width": 480,
      "height": 195,
      "text": "CREATE OR REPLACE SNOWFLAKE.ML.FORECAST model (\n  INPUT_DATA        => SYSTEM$REFERENCE('VIEW', view),\n  SERIES_COLNAME    => 'city',\n  TIMESTAMP_COLNAME => 'ds',\n  TARGET_COLNAME    => 'temp_max',\n  CONFIG_OBJECT     => { 'ON_ERROR': 'SKIP' }\n);\n\nCALL model!FORECAST(\n  FORECASTING_PERIODS => 7,\n  CONFIG_OBJECT       => {'prediction_interval': 0.95}\n);",
      "originalText": "CREATE OR REPLACE SNOWFLAKE.ML.FORECAST model (\n  INPUT_DATA        => SYSTEM$REFERENCE('VIEW', view),\n  SERIES_COLNAME    => 'city',\n  TIMESTAMP_COLNAME => 'ds',\n  TARGET_COLNAME    => 'temp_max',\n  CONFIG_OBJECT     => { 'ON_ERROR': 'SKIP' }\n);\n\nCALL model!FORECAST(\n  FORECASTING_PERIODS => 7,\n  CONFIG_OBJECT       => {'prediction_interval': 0.95}\n);",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
