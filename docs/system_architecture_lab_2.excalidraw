    {
      "type": "text",
      "id": "load_code_text",
      "x": 452,
      "y": 525,
      "width": 430,
      "height": 180,
      "text": "@task\ndef load(records, target_table):\n    con = snowflake.cursor()\n    try:\n        con.execute(\"BEGIN\")\n        con.execute(\"CREATE TABLE IF NOT EXISTS ...\")\n        con.execute(f\"DELETE FROM {target_table}\")\n        for v in records:\n            con.execute(\"INSERT INTO ... VALUES (...)\")\n        con.execute(\"COMMIT\")\n    except Exception as e:\n        con.execute(\"ROLLBACK\"); raise e",
      "originalText": "@task\ndef load(records, target_table):\n    con = snowflake.cursor()\n    try:\n        con.execute(\"BEGIN\")\n        con.execute(\"CREATE TABLE IF NOT EXISTS ...\")\n        con.execute(f\"DELETE FROM {target_table}\")\n        for v in records:\n            con.execute(\"INSERT INTO ... VALUES (...)\")\n        con.execute(\"COMMIT\")\n    except Exception as e:\n        con.execute(\"ROLLBACK\"); raise e",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
