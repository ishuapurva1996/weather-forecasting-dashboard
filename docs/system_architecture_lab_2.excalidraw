      "x": 72,
      "y": 355,
      "width": 276,
      "height": 160,
      "text": "GET /v1/forecast\n  latitude, longitude\n  past_days: 60\n  forecast_days: 0\n  daily:\n    temperature_2m_max\n    temperature_2m_min\n    temperature_2m_mean\n    weather_code\n  timezone: America/LA",
